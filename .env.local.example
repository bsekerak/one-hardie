# ── Anthropic (required) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs TTS (optional — chat works without it, no voice) ───────────────
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Voice ID — default is "Sarah" (warm, professional English).
# Browse voices at https://elevenlabs.io/app/voice-library
# Popular choices:
#   Sarah  (warm, neutral):     EXAVITQu4vr4xnSDxMaL
#   Adam   (deep, confident):   pNInz6obpgDQGcFmaJgB
#   Rachel (calm, clear):       21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
